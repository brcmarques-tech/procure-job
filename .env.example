# Banco — Postgres (local e produção apontam para o MESMO banco na nuvem).
# Pegue a connection string no Render/Neon. Formato:
# postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Claude API — https://console.anthropic.com
# Vazio = usa a assinatura do Claude Code (local). Em produção, defina a chave.
ANTHROPIC_API_KEY=""

# --- Contas / login multi-conta (nome + senha) ---
# SESSION_SECRET: assina o cookie de sessão. Vazio = login DESATIVADO (app aberto).
#   Defina um valor longo e aleatório (ex.: `openssl rand -hex 32`). MESMO valor
#   local e no Render.
# MASTER_PASSWORD: senha mestre que libera a tela /cadastro (criar contas novas).
SESSION_SECRET=""
MASTER_PASSWORD=""

# Cripto das credenciais do Freelancer no banco (AES-256-GCM). Vazio = guarda
# em texto puro. PRECISA ser o MESMO valor local e no Render (banco é o mesmo).
# Gere com: openssl rand -hex 32
CREDS_KEY=""

# (DEPRECATED) Login antigo por senha única compartilhada — substituído por
# SESSION_SECRET + contas. Mantido só como referência; não é mais usado.
APP_PASSWORD=""

# IA via Claude LOCAL (sem API key). O app no Render chama o seu notebook.
# - AI_PROXY_SECRET: segredo compartilhado (mesmo valor local e no Render).
# - AI_PROXY_URL: SÓ no Render — a URL do túnel + /api/ai-proxy. Local fica vazio.
AI_PROXY_SECRET=""
AI_PROXY_URL=""

# Freelancer.com API — https://developers.freelancer.com
# Token GLOBAL (ponte): uma conta só, usada por perfis SEM conexão própria,
# até o app OAuth (CLIENT_ID/SECRET) ser aprovado e cada perfil conectar a sua.
FREELANCER_OAUTH_TOKEN=""
FREELANCER_API_BASE="https://www.freelancer.com/api"
# OAuth2 "Conectar Freelancer"
FREELANCER_OAUTH_BASE="https://accounts.freelancer.com"
FREELANCER_CLIENT_ID=""
FREELANCER_CLIENT_SECRET=""
FREELANCER_REDIRECT_URI="http://localhost:3000/api/freelancer/callback"

# URL pública base do app (para montar o link do portfólio nas propostas)
APP_BASE_URL="http://localhost:3000"
# Base PÚBLICA usada nos links de portfólio dentro das propostas/lances.
# Default = deploy no Render. NUNCA usar localhost aqui (o cliente recebe esse link).
PUBLIC_BASE_URL="https://procure-job.onrender.com"

# Atlassian / Jira — https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_SITE="https://seu-time.atlassian.net"
ATLASSIAN_EMAIL=""
ATLASSIAN_API_TOKEN=""
ATLASSIAN_PROJECT_KEY="PROC"

# GitHub — https://github.com/settings/tokens
GITHUB_TOKEN=""

# Render — API de gerência (setar env vars do serviço via API).
# Key em https://dashboard.render.com/u/settings#api-keys (começa com rnd_).
RENDER_API_KEY=""
RENDER_SERVICE_ID=""

# Figma — https://www.figma.com/developers/api#access-tokens
# Token de acesso pessoal + chave do arquivo de referência de design.
FIGMA_TOKEN=""
FIGMA_FILE_KEY=""

# Magnific — geração/upscale de imagem (https://magnific.ai)
MAGNIFIC_API_KEY=""
MAGNIFIC_WEBHOOK_SECRET=""
