// Schema do banco — Procure.job
// Postgres (local e produção usam o MESMO banco na nuvem, então o portfólio
// gerado localmente já fica no ar). Arrays/objetos seguem guardados como
// String JSON — toda a lógica de JSON.parse() nas libs continua igual.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Conta de acesso à ferramenta (login por nome + senha). Cada conta vê só os
// perfis (User) dela. Cadastro protegido por senha mestre (env MASTER_PASSWORD).
model Account {
  id        String   @id @default(cuid())
  nome      String   @unique // identificador de login
  senhaHash String // scrypt: "salt:hash"
  createdAt DateTime @default(now())

  users User[]
}

model User {
  id         String   @id @default(cuid())
  nome       String
  email      String
  telefone   String? // contato (vira o WhatsApp do portfólio)
  linkedin   String? // URL do LinkedIn (botão do portfólio)
  idiomas    String   @default("[]") // JSON: string[]
  faixaPreco String?
  createdAt  DateTime @default(now())

  // Conta dona do perfil. Nullable: perfis antigos (pré-multiconta) e modo
  // "aberto" (sem SESSION_SECRET) ficam sem dono até a migração ligá-los.
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  profile        Profile?
  portfolio      Portfolio?
  channels       Channel[]
  portfoliosVaga PortfolioVaga[]
  jobs           Job[]

  // E-mail único POR conta (duas contas podem usar o mesmo e-mail).
  @@unique([accountId, email])
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  area          String
  skills        String   @default("[]") // JSON: string[]
  resumoBio     String
  experiencias  String   @default("[]") // JSON: {titulo, descricao, periodo?}[]
  keywordsBusca String   @default("[]") // JSON: string[] — termos usados na busca de vagas
  updatedAt     DateTime @updatedAt
}

model Portfolio {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  html       String   @default("")
  css        String   @default("")
  publicSlug String   @unique
  status     String   @default("draft") // draft | publicado
  images     String   @default("[]") // JSON: {role, url, prompt}[] — imagens geradas (Magnific)
  updatedAt  DateTime @updatedAt
}

// Versão temporária do portfólio, focada numa vaga específica.
// O usuário gera no fluxo da proposta e vê/exclui no Acompanhamento.
model PortfolioVaga {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId      String // Job.id de origem (liga ao acompanhamento)
  focoVaga   String // título da vaga (exibição)
  html       String   @default("")
  css        String   @default("")
  publicSlug String   @unique
  images     String   @default("[]") // reusa as imagens do portfólio principal
  createdAt  DateTime @default(now())

  @@unique([userId, jobId])
}

model Channel {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo        String // freelancer | workana | upwork
  credenciais String   @default("{}") // JSON com tokens, CIFRADO (AES-256-GCM) via lib/credsCrypto + CREDS_KEY
  modo        String   @default("copiloto") // auto | copiloto
  createdAt   DateTime @default(now())

  jobs Job[]

  @@unique([userId, tipo])
}

model Job {
  id         String   @id @default(cuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  // Dono direto da vaga salva (escopo por usuário + limpeza). A busca não
  // persiste mais nada; um Job só existe quando o usuário curtiu ou preparou.
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalId String // id da vaga na plataforma de origem
  titulo     String
  descricao  String
  budget     String?
  skills     String   @default("[]") // JSON: string[]
  score      Int      @default(0) // 0-100 compatibilidade com o perfil
  statusVaga String   @default("nova") // nova | salva | elegivel | descartada
  createdAt  DateTime @default(now())

  application Application?

  @@unique([channelId, externalId])
  @@index([userId])
}

model Application {
  id                 String    @id @default(cuid())
  jobId              String    @unique
  job                Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  propostaTexto      String
  valorSugerido      String?
  prazoSugerido      String?
  status             String    @default("rascunho") // rascunho | aguardando_envio | enviada | shortlist | aceita | recusada | respondida
  modoEnvio          String // auto | copiloto
  bidExternalId      String? // id do lance no Freelancer (para sincronizar status)
  enviadaEm          DateTime?
  respostaRecebidaEm DateTime?
  createdAt          DateTime  @default(now())

  events Event[]
}

// Imagem gerada do portfólio, guardada NO BANCO (durável e servida online,
// em vez de arquivo local que some no deploy do Render).
model GeneratedImage {
  id        String   @id @default(cuid())
  userId    String
  role      String // hero | sobre | trabalho
  mime      String   @default("image/jpeg")
  data      Bytes
  updatedAt DateTime @updatedAt

  @@unique([userId, role])
}

// Fotos de referência do usuário (data URIs base64), pra regenerar uma imagem
// sem reenviar tudo. Também no banco (antes era arquivo em data/refs).
model ImageRefs {
  userId    String   @id
  refs      String // JSON: string[] de data URIs
  updatedAt DateTime @updatedAt
}

// Config singleton — guarda a URL do túnel pro Claude local (atualizada pelo
// notebook quando liga o túnel; o app no Render lê daqui, sem precisar redeploy).
model AppConfig {
  id         String   @id @default("singleton")
  aiProxyUrl String?
  updatedAt  DateTime @updatedAt
}

model Event {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tipo          String // visualizada | respondida | entrevista
  payload       String      @default("{}") // JSON
  createdAt     DateTime    @default(now())
}
